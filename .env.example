# API Configuration
VUE_APP_API_BASE_URL=https://techcrunch.com/wp-json/wp/v2

# Cache Configuration (in milliseconds)
VUE_APP_CACHE_DURATION=1800000

# Blog Configuration
VUE_APP_ITEMS_PER_PAGE=6
VUE_APP_READING_WPM=200

# Feature Flags
VUE_APP_ENABLE_ANALYTICS=false
VUE_APP_ENABLE_FAVORITES=true
VUE_APP_ENABLE_SHARE=true

# Environment
VUE_APP_ENV=development
